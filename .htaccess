# CyberPunk Dark Theme - .htaccess Security Hardening
# Place this file in your WordPress root (wp-content/themes/cyberpunk-dark/.htaccess
# is for reference; the active one belongs at the WordPress root).
# This file documents the recommended server-level rules.

# ── Deny direct access to sensitive theme files ──────────────────────────────
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|phar)$">
    # Allow only WordPress entry points; block direct PHP execution in theme dir.
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Allow WordPress to load theme PHP files through its own loader (not directly).
# The above rule is intentionally strict for the theme directory.

# ── Prevent directory listing ─────────────────────────────────────────────────
Options -Indexes

# ── Block access to sensitive files ──────────────────────────────────────────
<FilesMatch "(^#.*#|\.(bak|conf|dist|fla|inc|ini|log|psd|sh|sql|sw[op])|~)$">
    Order Allow,Deny
    Deny from all
    Satisfy All
</FilesMatch>

# Block access to composer files, package manifests, and dot-files
<FilesMatch "^(composer\.(json|lock)|package(-lock)?\.json|yarn\.lock|\.env.*|\.git.*|Makefile|Dockerfile)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ── Security headers (Apache mod_headers) ────────────────────────────────────
# These complement the PHP-level headers in inc/security.php.
# Active when mod_headers is available (standard on Apache 2.4+).

<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set X-Permitted-Cross-Domain-Policies "none"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=()"

    # Cross-Origin isolation headers — mirror the PHP-level headers in inc/security.php.
    # COOP prevents cross-origin window references (opener attacks).
    Header always set Cross-Origin-Opener-Policy "same-origin"
    # CORP prevents other origins from loading this site's resources.
    Header always set Cross-Origin-Resource-Policy "same-origin"
    # COEP set to unsafe-none to avoid breaking Elementor/Google Fonts embeds.
    # Change to 'require-corp' once all third-party sub-resources opt in via CORP/CORS.
    Header always set Cross-Origin-Embedder-Policy "unsafe-none"

    # HSTS — enforces HTTPS for 1 year including subdomains.
    # Only active when the request arrives over HTTPS (env var set by mod_ssl).
    # Remove the condition and keep the bare Header directive only after you have
    # confirmed 100% HTTPS coverage across all subdomains and have a valid cert.
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS

    # Content-Security-Policy — mirrors the PHP-level CSP in inc/security.php.
    # 'unsafe-inline' and 'unsafe-eval' are required by Elementor; remove them
    # once you migrate to nonce-based or hash-based script loading.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; media-src 'self' blob:; connect-src 'self'; frame-src 'self'; frame-ancestors 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; worker-src 'self' blob:; upgrade-insecure-requests"
</IfModule>

# ── Disable server signature ──────────────────────────────────────────────────
# NOTE: ServerSignature and ServerTokens are server-level directives and cannot
# be set in .htaccess. Configure them in your Apache server config or vhost:
#
#   ServerSignature Off
#   ServerTokens Prod
#
# ServerTokens Prod limits the Server: response header to "Apache" only,
# preventing version disclosure. ServerSignature Off removes the server
# footer from error pages. Both must be set in httpd.conf or a vhost conf.
